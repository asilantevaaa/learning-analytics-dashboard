# Copy this file to server/.env and fill in real values.

# Base Grafana URL (no trailing slash) and service account token (Bearer).
# Both can also be set at runtime from the app's Settings page (director role) —
# whatever is saved there (server/data/grafana.json) takes priority over these.
# Create the token in Grafana: Administration -> Service accounts -> Add
# service account -> Add token. Needs Viewer access to the relevant
# dashboards/datasources.
GRAFANA_URL=https://grafana.example.com
GRAFANA_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Backend port
PORT=8787

# Name of the Grafana templating variable used for the per-employee filter
# on dashboard panels queried via server/grafana.js (collectDashboard/collect).
QUEUE_VAR=queue

# Datasource UID for ticket metrics (answers/transfers/delays). See server/metrics.js.
DS_TICKETS=your-tickets-datasource-uid

# Datasource UID for speed/time-tracking metrics. See server/metrics.js.
DS_SPEED=your-speed-datasource-uid

# Auto-collection schedule is configured in-app (Settings tab) and stored in
# server/data/settings.json. This only sets the timezone used by node-cron.
TZ=Europe/Moscow
